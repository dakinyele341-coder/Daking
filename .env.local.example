# ============================================================
# Skribbl — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. NEVER put server-only secrets
# behind a NEXT_PUBLIC_ prefix (that exposes them to the browser).
# ============================================================

# --- Supabase (public — safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase service role (SERVER ONLY) ---
# Bypasses ALL Row Level Security. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini (SERVER ONLY) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- ElevenLabs TTS (SERVER ONLY; optional) ---
# Powers the "Enhanced" AI narration voice. Leave blank to use browser TTS
# only (the voice toggle simply won't appear). Free tier: 10k chars/month.
ELEVENLABS_API_KEY=

# --- PostHog analytics (public; optional — analytics disabled if unset) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Email (Gmail SMTP; optional — emails disabled if unset) ---
# No domain needed: send from a Gmail address. GMAIL_APP_PASSWORD is a 16-char
# App Password (Google account → Security → 2-Step Verification → App passwords),
# NOT your normal Gmail password.
GMAIL_USER=skribbl.app@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_FROM=Skribbl <skribbl.app@gmail.com>
# Protects the lifecycle cron endpoint. Generate: openssl rand -hex 32
CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
